<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:focusable="true">

    <!-- Top Row: App Title & Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp">
        
        <TextView
            android:id="@+id/widget_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="📋 مهامي اليومية"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_add_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="إضافة مهمة ➕"
            android:textColor="#F59E0B"
            android:textSize="10sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#213E37"
        android:layout_marginBottom="8dp"/>

    <!-- Task List container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/widget_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_section_bg"
            android:padding="6dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- Delete target -->
            <TextView
                android:id="@+id/widget_task_delete_1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="🗑️"
                android:gravity="center"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"/>

            <!-- Category -->
            <TextView
                android:id="@+id/widget_task_cat_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عبادة"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:layout_marginStart="4dp"/>

            <!-- Task Title -->
            <TextView
                android:id="@+id/widget_task_title_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="مهمة 1"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:gravity="end"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:singleLine="true"/>

            <!-- Checkbox target -->
            <TextView
                android:id="@+id/widget_task_check_1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="⬜"
                android:gravity="center"
                android:textSize="14dp"
                android:textColor="#34D399"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"/>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/widget_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_section_bg"
            android:padding="6dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- Delete target -->
            <TextView
                android:id="@+id/widget_task_delete_2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="🗑️"
                android:gravity="center"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"/>

            <!-- Category -->
            <TextView
                android:id="@+id/widget_task_cat_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صحة"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:layout_marginStart="4dp"/>

            <!-- Task Title -->
            <TextView
                android:id="@+id/widget_task_title_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="مهمة 2"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:gravity="end"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:singleLine="true"/>

            <!-- Checkbox target -->
            <TextView
                android:id="@+id/widget_task_check_2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="⬜"
                android:gravity="center"
                android:textSize="14dp"
                android:textColor="#34D399"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"/>
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:id="@+id/widget_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_section_bg"
            android:padding="6dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- Delete target -->
            <TextView
                android:id="@+id/widget_task_delete_3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="🗑️"
                android:gravity="center"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"/>

            <!-- Category -->
            <TextView
                android:id="@+id/widget_task_cat_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عمل"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:layout_marginStart="4dp"/>

            <!-- Task Title -->
            <TextView
                android:id="@+id/widget_task_title_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="مهمة 3"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:gravity="end"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:singleLine="true"/>

            <!-- Checkbox target -->
            <TextView
                android:id="@+id/widget_task_check_3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="⬜"
                android:gravity="center"
                android:textSize="14dp"
                android:textColor="#34D399"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"/>
        </LinearLayout>

        <!-- Empty State Row -->
        <TextView
            android:id="@+id/widget_empty_state"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:gravity="center"
            android:text="لا توجد مهام اليوم! يوم ممتع وسعيد 🌿"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:visibility="visible"/>
    </LinearLayout>

</LinearLayout>
