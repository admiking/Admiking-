<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:focusable="true"
    android:clickable="true">

    <!-- Top Row: App Name and Location -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        
        <TextView
            android:id="@+id/widget_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="✨ حياتي"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="مكة المكرمة 📍"
            android:textColor="#94A3B8"
            android:textSize="10sp" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#213E37"
        android:layout_marginBottom="8dp"/>

    <!-- Content Row: Split into Tasks and Prayer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Left Side: Nearest Task -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center_vertical|end"
            android:background="@drawable/widget_section_bg"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌 المهمة القادمة"
                android:textColor="#A7F3D0"
                android:textSize="10sp"
                android:layout_gravity="end"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/widget_task_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="تلاوة الورد اليومي"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="end"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_task_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_gravity="end"
                android:text="التصنيف: عبادة"
                android:textColor="#94A3B8"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Right Side: Next Prayer -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_section_bg"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕌 صلاة قادمة"
                android:textColor="#A7F3D0"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/widget_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="الظهر"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/widget_prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="12:25 م"
                android:textColor="#F59E0B"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Row: Quick Tasbih Counter -->
    <LinearLayout
        android:id="@+id/widget_tasbih_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#154B3E"
        android:padding="6dp"
        android:layout_marginTop="6dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/widget_tasbih_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📿 تسبيح سريع: ٠ (اضغط للزيادة)"
            android:textColor="#34D399"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
