<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:focusable="true"
    android:clickable="true">

    <!-- Top Row: App Title -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        
        <TextView
            android:id="@+id/widget_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="💡 مسألة الفقه اليومية"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="الباب: الطهارة 📖"
            android:textColor="#94A3B8"
            android:textSize="10sp" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#213E37"
        android:layout_marginBottom="8dp"/>

    <!-- Question Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical|end"
        android:background="@drawable/widget_section_bg"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="السؤال المطروح:"
            android:textColor="#A7F3D0"
            android:textSize="9sp"
            android:layout_gravity="end"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_fiqh_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="ما حكم الوضوء من أكل لحم الإبل؟"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="end"
            android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Interactive Reveal / Details Row -->
    <LinearLayout
        android:id="@+id/widget_action_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#154B3E"
        android:padding="6dp"
        android:layout_marginTop="6dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/widget_action_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📜 اضغط لقراءة الجواب الشرعي المفصل"
            android:textColor="#34D399"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
